<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Styles.Resources>
        <ResourceDictionary>
            <!-- Colors -->
            <Color x:Key="SpaceBlack">#0A0A0F</Color>
            <Color x:Key="SpaceDark">#12121A</Color>
            <Color x:Key="SpaceMid">#1A1A2E</Color>
            <Color x:Key="SpaceLight">#2A2A3E</Color>
            <Color x:Key="Accent">#6C63FF</Color>
            <Color x:Key="AccentDim">#4A42CC</Color>
            <Color x:Key="TextPrimary">#E0E0F0</Color>
            <Color x:Key="TextSecondary">#8888AA</Color>
            <Color x:Key="BorderColor">#2A2A3E</Color>

            <!-- Brushes -->
            <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource SpaceBlack}" />
            <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource SpaceDark}" />
            <SolidColorBrush x:Key="PanelBorderBrush" Color="{StaticResource SpaceLight}" />
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="AccentDimBrush" Color="{StaticResource AccentDim}" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
        </ResourceDictionary>
    </Styles.Resources>

    <Style Selector="Window">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Button">
        <Setter Property="Background" Value="{StaticResource SpaceMid}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style Selector="Button:pointerover">
        <Setter Property="Background" Value="{StaticResource SpaceLight}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    </Style>

    <Style Selector="Button:pressed">
        <Setter Property="Background" Value="{StaticResource AccentDimBrush}" />
    </Style>

    <Style Selector="TextBox">
        <Setter Property="Background" Value="{StaticResource SpaceDark}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style Selector="TextBox:focus-within">
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    </Style>

    <Style Selector="ProgressBar">
        <Setter Property="Background" Value="{StaticResource SpaceMid}" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="3" />
    </Style>

    <Style Selector="ListBox">
        <Setter Property="Background" Value="{StaticResource SpaceDark}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="ListBoxItem:selected">
        <Setter Property="Background" Value="{StaticResource AccentDimBrush}" />
    </Style>

    <Style Selector="Separator">
        <Setter Property="Background" Value="{StaticResource BorderColor}" />
    </Style>
</Styles>
